<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zenbpm="http://zenbpm.pbinitiative.org/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_ZenForm"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_ZenForm" isExecutable="false">

    <!-- Create path: no extensionElements yet. -->
    <bpmn:userTask id="UserTask_empty" name="No mappings" />

    <!-- Create path, but extensionElements already exists (sibling). -->
    <bpmn:userTask id="UserTask_withSibling" name="Assignment only">
      <bpmn:extensionElements>
        <zenbpm:assignmentDefinition assignee="bob" />
      </bpmn:extensionElements>
    </bpmn:userTask>

    <!-- Edit path: ZEN_FORM input already present + a manual output to preserve. -->
    <bpmn:userTask id="UserTask_withFormAndManualOutput" name="Form + manual output">
      <bpmn:extensionElements>
        <zenbpm:ioMapping>
          <zenbpm:input source="=&quot;{}&quot;" target="ZEN_FORM" />
          <zenbpm:output source="=result" target="myResult" />
        </zenbpm:ioMapping>
      </bpmn:extensionElements>
    </bpmn:userTask>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ZenForm">
    <bpmndi:BPMNPlane id="BPMNPlane_ZenForm" bpmnElement="Process_ZenForm">
      <bpmndi:BPMNShape id="UserTask_empty_di" bpmnElement="UserTask_empty">
        <dc:Bounds x="100" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_withSibling_di" bpmnElement="UserTask_withSibling">
        <dc:Bounds x="240" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_withFormAndManualOutput_di" bpmnElement="UserTask_withFormAndManualOutput">
        <dc:Bounds x="380" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>