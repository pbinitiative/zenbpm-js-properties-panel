{
  "name": "@pbinitiative/zenbpm-js-properties-panel",
  "version": "0.3.1",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "karma start karma.config.cjs",
    "dev": "karma start karma.config.cjs --auto-watch --no-single-run",
    "prepublishOnly": "rm -rf dist && rollup -c"
  },
  "keywords": [
    "bpmn",
    "bpmn-js",
    "properties-panel",
    "zenbpm"
  ],
  "license": "MIT",
  "description": "ZenBPM properties panel provider for bpmn-js - adds ZenBPM-specific element properties",
  "author": "PB Initiative",
  "repository": {
    "type": "git",
    "url": "https://github.com/pbinitiative/zenbpm-js-properties-panel"
  },
  "homepage": "https://github.com/pbinitiative/zenbpm-js-properties-panel#readme",
