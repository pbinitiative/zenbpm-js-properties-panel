{
  "name": "@pbinitiative/zenbpm-js-properties-panel",
  "version": "0.3.1",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "rm -rf dist && rollup -c"
  },
  "keywords": [
    "bpmn",
    "bpmn-js",
    "properties-panel",
    "zenbpm"
  ],
  "license": "MIT",
  "description": "ZenBPM properties panel provider for bpmn-js - adds ZenBPM-specific element properties",
  "author": "PB Initiative",
  "repository": {
    "type": "git",
    "url": "https://github.com/pbinitiative/zenbpm-js-properties-panel"
  },
  "homepage": "https://github.com/pbinitiative/zenbpm-js-properties-panel#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.9.1",
    "rollup": "^4.60.4",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@pbinitiative/zenbpm-bpmn-moddle": "^0.1.0"
  },
  "peerDependencies": {
    "@bpmn-io/properties-panel": ">= 3.7",
    "bpmn-js": ">= 11.5",
    "bpmn-js-properties-panel": ">= 5"
  }
}
