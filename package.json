    "raw-loader": "^4.0.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "semver": "^7.8.5",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2"
  },
  "dependencies": {
    "@pbinitiative/zenbpm-bpmn-moddle": "^0.1.0"
  },
